# Copy this file to .env.local for local development.
# For production, set these values in the Netlify dashboard:
#   Site settings → Environment variables

# The base URL of the Spring Boot API.
# Local dev: Vite proxy rewrites /api/* so this can stay as-is.
# Production: Set to your Render service URL, e.g. https://clinical-trial-api.onrender.com/api
VITE_API_BASE_URL=http://localhost:8080/api
